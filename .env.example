PORT=3000
NODE_ENV=development

# Optional Riipen API mode
RIIPEN_API_BASE_URL=https://api.riipen.com/api/v1
RIIPEN_SECRET_KEY=sk_your_secret_key
RIIPEN_WEBHOOK_SECRET=replace_me

# Discord
DISCORD_BOT_TOKEN=replace_me
DISCORD_APPLICATION_ID=replace_me
DISCORD_GUILD_ID=replace_me
DISCORD_ALERTS_CHANNEL_ID=replace_me

# Google (Gmail + Calendar)
GOOGLE_CLIENT_ID=replace_me
GOOGLE_CLIENT_SECRET=replace_me
GOOGLE_REDIRECT_URI=http://localhost
GOOGLE_REFRESH_TOKEN=replace_me
GOOGLE_CALENDAR_ID=primary

# Gmail polling
GMAIL_QUERY=from:riipen newer_than:7d
GMAIL_POLL_INTERVAL_MS=60000

# Milestone reminders
MILESTONE_REMINDER_INTERVAL_MS=21600000
MILESTONE_REMINDER_CHECK_MS=300000

# Storage
SQLITE_PATH=./data/riipen-companion.sqlite
